# =============================================================
# Yubling — Environment Variables Template
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git
# =============================================================

# ── Supabase ──────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── Site URL (for OAuth redirect) ─────────────────────────
# Local:      http://localhost:3000
# Production: https://yubling.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── YouTube Data API v3 ───────────────────────────────────
# Get from: https://console.cloud.google.com → Credentials
# Enable: YouTube Data API v3
# Quota: 10,000 units/day (free)
# Cost per tool:
#   Tag Extractor  = 1 unit   (videos.list)
#   Viral Search   = 100 units (search.list)
#   Channel Copy   = 100+ units
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY

# ── Google OAuth (Supabase handles this) ─────────────────
# Configure in: Supabase Dashboard → Authentication → Providers → Google
# Then set authorized redirect URI in Google Cloud Console:
# https://YOUR_PROJECT_ID.supabase.co/auth/v1/callback

# ── Gemini (coming soon) ─────────────────────────────────
# GEMINI_API_KEY=YOUR_GEMINI_KEY

# ── Paddle (coming last — after product is complete) ─────
# PADDLE_API_KEY=YOUR_PADDLE_KEY
# PADDLE_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=YOUR_CLIENT_TOKEN
